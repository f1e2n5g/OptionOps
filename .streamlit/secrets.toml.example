# OptionOps — secrets 範本
# 1. 複製此檔：  cp .streamlit/secrets.toml.example .streamlit/secrets.toml
# 2. 填入真實值（secrets.toml 已被 .gitignore 排除，不會進入版本控制）
# 3. Streamlit Community Cloud 請在 App Settings → Secrets 貼入相同內容

APP_PASSWORD  = "change_me_now"   # 存取密碼（留空 = 開發模式，不驗證）

FINMIND_TOKEN = ""                 # 選填：finmindtrade.com 申請
                                   # 空字串 = 免費 300 req/hr
                                   # 有 token = 600 req/hr
